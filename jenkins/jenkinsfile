pipeline {
    agent any

    stages {
        stage('Unit Test BackEnd') {
            agent {
                docker {
                    image 'snakee/golang-junit:1.21'
                    args '-e GOCACHE=/tmp/go-build -e GOMODCACHE=/tmp/go-mod -e HOME=/home/jenkins'
                    reuseNode true
                }
            }
            steps {
                dir('bugtracker-backend') {
                    sh '''
                        go test ./... -v 2>&1 | go-junit-report > test-results.xml

                        #Generate covergage report
                        go test -coverprofile coverage.out -covermode atomic ./...
                        go tool cover -html coverage.out -o coverage.html

                        mkdir -p reports
                        mv test-results.xml reports/
                        mv coverage.html reports/

                       ''' 
                }
                
            }
            post {
                always {
                    junit 'bugtracker-backend/reports/test-results.xml'
                    publishHTML target: [
                        reportName: 'Backend Coverage Report',
                        reportDir: 'bugtracker-backend/reports',
                        reportFiles: 'coverage.html',
                        keepAll: true,
                        allowMissing: false,
                        alwaysLinkToLastBuild: true,
                        keepAllInSameBuild: true
                    ]
                }
            }
        }

         stage('Unit Test FrontEnd') {
            agent {
                docker {
                    image 'node:20-alpine'
                   // args '-e GOCACHE=/tmp/go-build -e GOMODCACHE=/tmp/go-mod -e HOME=/home/jenkins'
                    reuseNode true
                }
            }
            steps {
                dir('bugtracker-frontend') {
                    sh '''
                        npm ci
                        npm test
                    '''
                }
            }
            post {
                always {
                    junit 'bugtracker-frontend/test-results.xml'
                }
            }
        }
    }
}